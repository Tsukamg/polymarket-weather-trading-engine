# Copy to `.env` and adjust. All keys are optional except secrets you rely on.

# Paper / sim starting balance (USD)
WEATHERBOT_BALANCE=10000

# Max notional per trade (USD)
WEATHERBOT_MAX_BET=20

# Minimum expected value to enter (e.g. 0.1 = 10% edge)
WEATHERBOT_MIN_EV=0.1

# Do not buy if YES ask is at or above this price
WEATHERBOT_MAX_PRICE=0.45

# Minimum outcome volume (USD) on Polymarket
WEATHERBOT_MIN_VOLUME=500

# Only trade if resolution is between these hour windows
WEATHERBOT_MIN_HOURS=2
WEATHERBOT_MAX_HOURS=72

# Fraction Kelly (e.g. 0.25 = quarter Kelly)
WEATHERBOT_KELLY_FRACTION=0.25

# Max bid–ask spread (dollars) to allow entry
WEATHERBOT_MAX_SLIPPAGE=0.03

# Seconds between full market scans
WEATHERBOT_SCAN_INTERVAL=3600

# Resolved markets needed before calibration updates sigmas
WEATHERBOT_CALIBRATION_MIN=30

# Visual Crossing API key (actual temps / resolution helpers)
WEATHERBOT_VC_KEY=

# Set to 1 to route entries/exits through Polymarket CLOB (requires keys below).
# Unset / 0 = paper trading (Gamma prices only).
WEATHERBOT_CLOB_LIVE=

# -----------------------------------------------------------------------------
# Polymarket live trading (Polygon) — put real values only in `.env`, never commit.
# Used when WEATHERBOT_CLOB_LIVE=1 (via @polymarket/clob-client).
# -----------------------------------------------------------------------------
# EOA private key that controls your Polymarket proxy (no 0x prefix required)
WEATHERBOT_POLY_PRIVATE_KEY=
# Proxy / funder address shown in Polymarket (holds USDC for trading)
WEATHERBOT_POLY_PROXY_WALLET=
# Chain ID (137 = Polygon mainnet, 80002 = Amoy testnet)
WEATHERBOT_POLY_CHAIN_ID=137
# CLOB EIP-712 flavour: 0 = EOA, 1 = Polymarket proxy wallet (usual), 2 = Gnosis safe
WEATHERBOT_POLY_SIGNATURE_TYPE=1
# Market orders: FOK (fill-or-kill) vs FAK (partial ok). Defaults: FAK for both legs.
WEATHERBOT_CLOB_ENTRY_ORDER_TYPE=FAK
WEATHERBOT_CLOB_EXIT_ORDER_TYPE=FAK
# Optional: CLOB API credentials if your SDK stack needs them (after L1/L2 setup)
WEATHERBOT_POLY_CLOB_API_KEY=
WEATHERBOT_POLY_CLOB_API_SECRET=
WEATHERBOT_POLY_CLOB_API_PASSPHRASE=
